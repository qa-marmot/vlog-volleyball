{
  "name": "vlog-volleyball",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev --compatibility-date=2024-09-23 -- astro dev",
    "build": "astro build && node scripts/fix-wrangler.mjs",
    "preview": "wrangler pages dev ./dist",
    "astro": "astro",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply vlog-volleyball --local",
    "db:migrate:remote": "wrangler d1 migrations apply vlog-volleyball --remote"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.8",
    "@astrojs/react": "^5.0.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@types/recharts": "^1.8.29",
    "astro": "^6.1.5",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "lucide-react": "^1.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-is": "^19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260408.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.81.0"
  }
}
