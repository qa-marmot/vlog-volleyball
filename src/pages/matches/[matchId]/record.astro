---
import Base from '../../../layouts/Base.astro'
import { MatchRecorder } from '../../../components/match/MatchRecorder'
import { getDb } from '../../../lib/db'
import { matches, teamMembers, players, teams } from '../../../schema'
import { eq, and } from 'drizzle-orm'
import type { Player } from '../../../types'

const user = Astro.locals.user!
import { env } from 'cloudflare:workers'
const db = getDb(env.DB)
const { matchId } = Astro.params as { matchId: string }

const match = await db.select().from(matches).where(eq(matches.id, matchId)).get()
if (!match) return Astro.redirect('/dashboard')

const membership = await db.select().from(teamMembers)
  .where(and(eq(teamMembers.teamId, match.teamId), eq(teamMembers.userId, user.id))).get()
if (!membership) return Astro.redirect('/dashboard')

if (match.status === 'completed') return Astro.redirect(`/matches/${matchId}/result`)

const team = await db.select().from(teams).where(eq(teams.id, match.teamId)).get()
const teamPlayers = await db.select().from(players).where(eq(players.teamId, match.teamId))

// Map Drizzle camelCase to snake_case for React components
const playersForClient: Player[] = teamPlayers.map((p) => ({
  id: p.id,
  team_id: p.teamId,
  name: p.name,
  number: p.number,
  position: p.position as Player['position'],
  is_libero: p.isLibero,
  created_at: p.createdAt,
}))
---
<Base title="試合記録">
  <div class="min-h-screen bg-slate-50">
    <header class="app-header px-4 py-3 sticky top-0 z-10">
      <div class="max-w-lg mx-auto flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/dashboard" class="text-slate-400 hover:text-white text-sm transition-colors">←</a>
          <div>
            <div class="text-sm font-semibold text-white">{team?.name} <span class="text-slate-400">vs</span> {match.opponentName}</div>
            <div class="text-xs text-slate-400">{match.matchDate}</div>
          </div>
        </div>
        <span class="badge-active">● 記録中</span>
      </div>
    </header>

    <main class="max-w-lg mx-auto p-4">
      <MatchRecorder
        client:load
        matchId={matchId}
        teamId={match.teamId}
        teamName={team?.name ?? '自チーム'}
        opponentName={match.opponentName}
        matchDate={match.matchDate}
        shareUuid={match.shareUuid}
        players={playersForClient}
      />
    </main>
  </div>
</Base>
