---
import Base from '../../layouts/Base.astro'
import { getDb } from '../../lib/db'
import { teamMembers, teams } from '../../schema'
import { eq } from 'drizzle-orm'

const user = Astro.locals.user!
const env = Astro.locals.runtime.env
const db = getDb(env.DB)

const memberships = await db.select({ team: teams })
  .from(teamMembers).innerJoin(teams, eq(teamMembers.teamId, teams.id))
  .where(eq(teamMembers.userId, user.id))

if (memberships.length === 0) return Astro.redirect('/dashboard')

// Pre-select team from query param
const preselectedTeamId = Astro.url.searchParams.get('teamId') ?? ''
const today = new Date().toISOString().slice(0, 10)
---
<Base title="試合を記録">
  <div class="min-h-screen bg-gray-50">
    <header class="bg-white border-b px-4 py-3 flex items-center gap-3 sticky top-0">
      <a href="/dashboard" class="text-gray-500 hover:text-gray-700 text-sm">← ダッシュボード</a>
      <span class="font-semibold">試合を記録</span>
    </header>

    <main class="max-w-md mx-auto p-4">
      <div class="bg-white rounded-xl border p-6 space-y-4">
        <form id="new-match-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-1" for="teamId">チーム</label>
            <select id="teamId" name="teamId" required
              class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
              {memberships.map(({ team }) => (
                <option value={team.id} selected={team.id === preselectedTeamId}>
                  {team.name}
                </option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1" for="opponentName">相手チーム名</label>
            <input id="opponentName" name="opponentName" type="text" required placeholder="例：○○高校"
              class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1" for="matchDate">試合日</label>
            <input id="matchDate" name="matchDate" type="date" required value={today}
              class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1" for="location">場所（任意）</label>
            <input id="location" name="location" type="text" placeholder="例：第一体育館"
              class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
          <p id="error-msg" class="text-red-500 text-sm hidden"></p>
          <button type="submit"
            class="w-full bg-blue-600 text-white rounded-lg py-2.5 font-medium text-sm hover:bg-blue-700 disabled:opacity-50">
            記録を開始する
          </button>
        </form>
      </div>
    </main>
  </div>
</Base>

<script>
  const form = document.getElementById('new-match-form') as HTMLFormElement
  const errorMsg = document.getElementById('error-msg') as HTMLParagraphElement
  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    btn.disabled = true
    btn.textContent = '作成中...'
    errorMsg.classList.add('hidden')

    const fd = new FormData(form)
    const venue = (fd.get('location') as string)?.trim()
    const res = await fetch('/api/matches', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        teamId: fd.get('teamId'),
        opponentName: fd.get('opponentName'),
        matchDate: fd.get('matchDate'),
        location: venue || undefined,
      }),
    })

    if (res.ok) {
      const data = await res.json() as { id: string }
      window.location.href = `/matches/${data.id}/record`
    } else {
      const data = await res.json() as { error?: string }
      errorMsg.textContent = data.error ?? 'エラーが発生しました'
      errorMsg.classList.remove('hidden')
      btn.disabled = false
      btn.textContent = '記録を開始する'
    }
  })
</script>
