---
import Base from '../../layouts/Base.astro'
import { getDb } from '../../lib/db'
import { teamMembers, teams } from '../../schema'
import { eq } from 'drizzle-orm'

const user = Astro.locals.user!
import { env } from 'cloudflare:workers'
const db = getDb(env.DB)

const memberships = await db.select({ team: teams })
  .from(teamMembers).innerJoin(teams, eq(teamMembers.teamId, teams.id))
  .where(eq(teamMembers.userId, user.id))

if (memberships.length === 0) return Astro.redirect('/dashboard')

const preselectedTeamId = Astro.url.searchParams.get('teamId') ?? ''
const today = new Date().toISOString().slice(0, 10)
---
<Base title="試合を記録">
  <div class="min-h-screen bg-slate-50">
    <header class="app-header px-4 py-3 sticky top-0 z-10">
      <div class="max-w-2xl mx-auto flex items-center gap-3">
        <a href="/dashboard" class="text-slate-400 hover:text-white text-sm transition-colors">← ダッシュボード</a>
        <span class="text-slate-600">|</span>
        <span class="text-sm font-semibold text-white">試合を記録</span>
      </div>
    </header>

    <main class="max-w-md mx-auto p-4 pt-6">
      <div class="card p-6">
        <h1 class="text-base font-semibold text-slate-900 mb-5">試合情報</h1>
        <form id="new-match-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5" for="teamId">チーム</label>
            <select id="teamId" name="teamId" required class="field-input">
              {memberships.map(({ team }) => (
                <option value={team.id} selected={team.id === preselectedTeamId}>{team.name}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5" for="opponentName">相手チーム名</label>
            <input id="opponentName" name="opponentName" type="text" required placeholder="例：○○高校"
              class="field-input" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5" for="matchDate">試合日</label>
            <input id="matchDate" name="matchDate" type="date" required value={today}
              class="field-input" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5" for="location">場所（任意）</label>
            <input id="location" name="location" type="text" placeholder="例：第一体育館"
              class="field-input" />
          </div>
          <p id="error-msg" class="hidden text-sm text-red-600 bg-red-50 border border-red-100 rounded px-3 py-2"></p>
          <button type="submit" class="btn-accent w-full py-2.5">記録を開始する</button>
        </form>
      </div>
    </main>
  </div>
</Base>

<script>
  const form = document.getElementById('new-match-form') as HTMLFormElement
  const errorMsg = document.getElementById('error-msg') as HTMLParagraphElement
  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    btn.disabled = true
    btn.textContent = '作成中...'
    errorMsg.classList.add('hidden')

    const fd = new FormData(form)
    const venue = (fd.get('location') as string)?.trim()
    const res = await fetch('/api/matches', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        teamId: fd.get('teamId'),
        opponentName: fd.get('opponentName'),
        matchDate: fd.get('matchDate'),
        location: venue || undefined,
      }),
    })

    if (res.ok) {
      const data = await res.json() as { id: string }
      window.location.href = `/matches/${data.id}/record`
    } else {
      const data = await res.json() as { error?: string }
      errorMsg.textContent = data.error ?? 'エラーが発生しました'
      errorMsg.classList.remove('hidden')
      btn.disabled = false
      btn.textContent = '記録を開始する'
    }
  })
</script>
