---
import Base from '../layouts/Base.astro'
import { getDb } from '../lib/db'
import { teamMembers, teams, matches } from '../schema'
import { eq, inArray, desc } from 'drizzle-orm'

const user = Astro.locals.user!
import { env } from 'cloudflare:workers'
const db = getDb(env.DB)

const memberships = await db.select({ role: teamMembers.role, team: teams })
  .from(teamMembers).innerJoin(teams, eq(teamMembers.teamId, teams.id))
  .where(eq(teamMembers.userId, user.id))

const teamIds = memberships.map((m) => m.team.id)
const recentMatches = teamIds.length > 0
  ? await db.select().from(matches).where(inArray(matches.teamId, teamIds)).orderBy(desc(matches.createdAt)).limit(20)
  : []
---
<Base title="ダッシュボード">
  <div class="min-h-screen bg-slate-50">
    <!-- Header -->
    <header class="app-header px-4 py-3 sticky top-0 z-10">
      <div class="max-w-2xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" class="opacity-80">
            <circle cx="8" cy="8" r="6.5" stroke="white" stroke-width="1.5"/>
            <path d="M8 1.5C8 1.5 5 5 5 8s3 6.5 3 6.5" stroke="white" stroke-width="1.5"/>
            <path d="M1.5 8h13" stroke="white" stroke-width="1.5"/>
          </svg>
          <span class="font-bold text-white tracking-tight">V-Log</span>
        </div>
        <div class="flex items-center gap-3">
          <a href="/help" class="text-xs text-slate-400 hover:text-slate-200 transition-colors">使い方</a>
          <button id="logout-btn" class="text-xs text-slate-400 hover:text-slate-200 transition-colors">ログアウト</button>
        </div>
      </div>
    </header>

    <main class="max-w-2xl mx-auto p-4 space-y-6">
      <!-- Teams -->
      <section>
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-sm font-semibold text-slate-900">チーム</h2>
          <div class="flex gap-2">
            <a href="/teams/join" class="btn-secondary text-xs px-3 py-1.5">招待コードで参加</a>
            <a href="/teams/new" class="btn-primary text-xs px-3 py-1.5">+ 作成</a>
          </div>
        </div>

        {memberships.length > 0 ? (
          <div class="card divide-y divide-slate-100">
            {memberships.map(({ role, team }) => (
              <div class="flex items-center justify-between px-4 py-3 hover:bg-slate-50 transition-colors">
                <a href={`/teams/${team.id}`} class="flex-1 min-w-0 mr-3">
                  <span class="text-sm font-medium text-slate-800 block truncate">{team.name}</span>
                  <div class="flex items-center gap-2 mt-0.5">
                    <span class="font-mono text-xs text-slate-400">{team.inviteCode}</span>
                    <span class={role === 'owner' ? 'badge-owner' : 'badge-member'}>
                      {role === 'owner' ? 'オーナー' : 'メンバー'}
                    </span>
                  </div>
                </a>
                {role === 'owner' && (
                  <button
                    data-team-id={team.id}
                    data-team-name={team.name}
                    class="delete-team-btn text-xs text-slate-300 hover:text-red-500 transition-colors px-2 py-1 shrink-0"
                  >
                    削除
                  </button>
                )}
              </div>
            ))}
          </div>
        ) : (
          <div class="card px-4 py-8 text-center">
            <p class="text-sm text-slate-500">チームがありません</p>
            <p class="text-xs text-slate-400 mt-1">チームを作成するか、招待コードで参加してください</p>
          </div>
        )}
      </section>

      <!-- Matches -->
      <section>
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-sm font-semibold text-slate-900">試合履歴</h2>
          {teamIds.length > 0 && (
            <a href="/matches/new" class="btn-accent text-xs px-3 py-1.5">+ 試合を記録</a>
          )}
        </div>

        {recentMatches.length > 0 ? (
          <div class="card divide-y divide-slate-100">
            {recentMatches.map((match) => {
              const membership = memberships.find(m => m.team.id === match.teamId)
              const teamName = membership?.team.name ?? ''
              const isOwner = membership?.role === 'owner'
              const href = match.status === 'in_progress'
                ? `/matches/${match.id}/record`
                : `/matches/${match.id}/result`
              return (
                <div class="flex items-center justify-between px-4 py-3 hover:bg-slate-50 transition-colors">
                  <a href={href} class="flex-1 min-w-0 mr-3">
                    <div class="text-sm font-medium text-slate-800 truncate">
                      {teamName} <span class="text-slate-400 font-normal">vs</span> {match.opponentName}
                    </div>
                    <div class="text-xs text-slate-400 mt-0.5">{match.matchDate}</div>
                  </a>
                  <div class="flex items-center gap-2 shrink-0">
                    <span class={match.status === 'completed' ? 'badge-done' : 'badge-active'}>
                      {match.status === 'completed' ? '終了' : '● 進行中'}
                    </span>
                    {isOwner && (
                      <button
                        data-match-id={match.id}
                        data-match-name={`${teamName} vs ${match.opponentName}`}
                        class="delete-match-btn text-xs text-slate-300 hover:text-red-500 transition-colors px-2 py-1"
                      >
                        削除
                      </button>
                    )}
                  </div>
                </div>
              )
            })}
          </div>
        ) : (
          <div class="card px-4 py-8 text-center">
            <p class="text-sm text-slate-500">試合履歴がありません</p>
            {teamIds.length > 0 && (
              <a href="/matches/new" class="inline-block mt-3 btn-accent text-xs px-4 py-1.5">+ 試合を記録</a>
            )}
          </div>
        )}
      </section>
    </main>
  </div>
</Base>

<script>
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' })
    location.href = '/login'
  })

  document.querySelectorAll('.delete-team-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation()
      const el = e.currentTarget as HTMLElement
      if (!confirm(`「${el.dataset.teamName}」を削除しますか？\nチームの選手・試合記録がすべて削除されます。`)) return
      const res = await fetch(`/api/teams/${el.dataset.teamId}`, { method: 'DELETE' })
      if (res.ok) location.reload()
      else alert('削除に失敗しました')
    })
  })

  document.querySelectorAll('.delete-match-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation()
      const el = e.currentTarget as HTMLElement
      if (!confirm(`「${el.dataset.matchName}」を削除しますか？`)) return
      const res = await fetch(`/api/matches/${el.dataset.matchId}`, { method: 'DELETE' })
      if (res.ok) location.reload()
      else alert('削除に失敗しました')
    })
  })
</script>
