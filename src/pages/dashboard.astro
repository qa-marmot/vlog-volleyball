---
import Base from '../layouts/Base.astro'
import { getDb } from '../lib/db'
import { teamMembers, teams, matches } from '../schema'
import { eq, inArray } from 'drizzle-orm'

const user = Astro.locals.user!
import { env } from 'cloudflare:workers'
const db = getDb(env.DB)

const memberships = await db.select({ role: teamMembers.role, team: teams })
  .from(teamMembers).innerJoin(teams, eq(teamMembers.teamId, teams.id))
  .where(eq(teamMembers.userId, user.id))

const teamIds = memberships.map((m) => m.team.id)
const recentMatches = teamIds.length > 0
  ? await db.select().from(matches).where(inArray(matches.teamId, teamIds)).limit(10)
  : []
---
<Base title="ダッシュボード">
  <div class="min-h-screen bg-gray-50">
    <header class="bg-white border-b px-4 py-3 flex items-center justify-between sticky top-0">
      <span class="text-xl font-bold text-blue-600">V-Log</span>
      <button id="logout-btn" class="text-sm text-gray-500 hover:text-gray-700">ログアウト</button>
    </header>

    <main class="max-w-2xl mx-auto p-4 space-y-6">
      <!-- チーム -->
      <section>
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold">チーム</h2>
          <div class="flex gap-2">
            <a href="/teams/join" class="text-sm border rounded-lg px-3 py-1.5 hover:bg-gray-50">コードで参加</a>
            <a href="/teams/new" class="text-sm bg-blue-600 text-white rounded-lg px-3 py-1.5 hover:bg-blue-700">+ 新規作成</a>
          </div>
        </div>
        {memberships.length > 0 ? (
          <div class="space-y-2">
            {memberships.map(({ role, team }) => (
              <a href={`/teams/${team.id}`} class="flex items-center justify-between bg-white rounded-xl border px-4 py-3 hover:bg-gray-50 transition-colors block">
                <span class="font-medium">{team.name}</span>
                <div class="flex items-center gap-2">
                  <span class="font-mono text-xs text-gray-400">{team.inviteCode}</span>
                  <span class={`text-xs px-2 py-0.5 rounded-full ${role === 'owner' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-600'}`}>
                    {role === 'owner' ? 'オーナー' : 'メンバー'}
                  </span>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="bg-white rounded-xl border px-4 py-6 text-center text-sm text-gray-500">
            チームがありません。作成または招待コードで参加してください。
          </div>
        )}
      </section>

      <!-- 試合履歴 -->
      <section>
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold">試合履歴</h2>
          {teamIds.length > 0 && (
            <a href="/matches/new" class="text-sm bg-blue-600 text-white rounded-lg px-3 py-1.5 hover:bg-blue-700">+ 試合を記録</a>
          )}
        </div>
        {recentMatches.length > 0 ? (
          <div class="space-y-2">
            {recentMatches.map((match) => (
              <div class="flex items-center justify-between bg-white rounded-xl border px-4 py-3">
                <div>
                  <div class="font-medium text-sm">{memberships.find(m => m.team.id === match.teamId)?.team.name} vs {match.opponentName}</div>
                  <div class="text-xs text-gray-400">{match.matchDate}</div>
                </div>
                <div class="flex items-center gap-2">
                  <span class={`text-xs px-2 py-0.5 rounded-full ${match.status === 'completed' ? 'bg-gray-100 text-gray-600' : 'bg-green-100 text-green-700'}`}>
                    {match.status === 'completed' ? '終了' : '進行中'}
                  </span>
                  <div class="flex gap-1">
                    {match.status === 'in_progress' && (
                      <a href={`/matches/${match.id}/record`} class="text-xs border rounded px-2 py-1 hover:bg-gray-50">記録</a>
                    )}
                    <a href={`/matches/${match.id}/result`} class="text-xs text-gray-500 hover:text-gray-700 px-2 py-1">結果</a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="bg-white rounded-xl border px-4 py-6 text-center text-sm text-gray-500">
            試合履歴がありません。
          </div>
        )}
      </section>
    </main>
  </div>
</Base>

<script>
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' })
    location.href = '/login'
  })
</script>
