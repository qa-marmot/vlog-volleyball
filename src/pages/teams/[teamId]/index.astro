---
import Base from '../../../layouts/Base.astro'
import { getDb } from '../../../lib/db'
import { teams, teamMembers, players, matches } from '../../../schema'
import { eq, and, desc } from 'drizzle-orm'

const user = Astro.locals.user!
const env = Astro.locals.runtime.env
const db = getDb(env.DB)
const { teamId } = Astro.params as { teamId: string }

const membership = await db.select().from(teamMembers)
  .where(and(eq(teamMembers.teamId, teamId), eq(teamMembers.userId, user.id))).get()

if (!membership) return Astro.redirect('/dashboard')

const team = await db.select().from(teams).where(eq(teams.id, teamId)).get()
if (!team) return Astro.redirect('/dashboard')

const teamPlayers = await db.select().from(players).where(eq(players.teamId, teamId))
const recentMatches = await db.select().from(matches)
  .where(eq(matches.teamId, teamId))
  .orderBy(desc(matches.createdAt))
  .limit(10)

const isOwner = membership.role === 'owner'
const positionLabel: Record<string, string> = {
  S: 'セッター', OH: 'アウトサイドヒッター', MB: 'ミドルブロッカー',
  OP: 'オポジット', L: 'リベロ',
}
---
<Base title={team.name}>
  <div class="min-h-screen bg-gray-50">
    <header class="bg-white border-b px-4 py-3 flex items-center justify-between sticky top-0">
      <div class="flex items-center gap-3">
        <a href="/dashboard" class="text-gray-500 hover:text-gray-700 text-sm">←</a>
        <span class="font-semibold">{team.name}</span>
      </div>
      <span class="font-mono text-xs text-gray-400 bg-gray-100 rounded px-2 py-1">{team.inviteCode}</span>
    </header>

    <main class="max-w-2xl mx-auto p-4 space-y-6">
      <!-- 選手一覧 -->
      <section>
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold">選手一覧</h2>
          {isOwner && (
            <a href={`/teams/${teamId}/players/new`} class="text-sm bg-blue-600 text-white rounded-lg px-3 py-1.5 hover:bg-blue-700">
              + 選手を追加
            </a>
          )}
        </div>
        {teamPlayers.length > 0 ? (
          <div class="space-y-2">
            {teamPlayers.map((p) => (
              <div class="flex items-center justify-between bg-white rounded-xl border px-4 py-3">
                <div class="flex items-center gap-3">
                  <span class="font-mono text-lg font-bold text-gray-300 w-8 text-right">#{p.number}</span>
                  <div>
                    <div class="font-medium text-sm">{p.name}</div>
                    {p.position && (
                      <div class="text-xs text-gray-400">{positionLabel[p.position] ?? p.position}</div>
                    )}
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  {p.isLibero && (
                    <span class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">リベロ</span>
                  )}
                  {isOwner && (
                    <button
                      data-player-id={p.id}
                      data-player-name={p.name}
                      class="delete-player-btn text-xs text-red-400 hover:text-red-600 px-2 py-1"
                    >
                      削除
                    </button>
                  )}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="bg-white rounded-xl border px-4 py-6 text-center text-sm text-gray-500">
            選手が登録されていません。
          </div>
        )}
      </section>

      <!-- 試合履歴 -->
      <section>
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold">試合履歴</h2>
          <a href={`/matches/new?teamId=${teamId}`} class="text-sm bg-blue-600 text-white rounded-lg px-3 py-1.5 hover:bg-blue-700">
            + 試合を記録
          </a>
        </div>
        {recentMatches.length > 0 ? (
          <div class="space-y-2">
            {recentMatches.map((match) => (
              <div class="flex items-center justify-between bg-white rounded-xl border px-4 py-3">
                <div>
                  <div class="font-medium text-sm">{team.name} vs {match.opponentName}</div>
                  <div class="text-xs text-gray-400">{match.matchDate}{match.location ? `・${match.location}` : ''}</div>
                </div>
                <div class="flex items-center gap-2">
                  <span class={`text-xs px-2 py-0.5 rounded-full ${match.status === 'completed' ? 'bg-gray-100 text-gray-600' : 'bg-green-100 text-green-700'}`}>
                    {match.status === 'completed' ? '終了' : '進行中'}
                  </span>
                  <div class="flex gap-1">
                    {match.status === 'in_progress' && (
                      <a href={`/matches/${match.id}/record`} class="text-xs border rounded px-2 py-1 hover:bg-gray-50">記録</a>
                    )}
                    <a href={`/matches/${match.id}/result`} class="text-xs text-gray-500 hover:text-gray-700 px-2 py-1">結果</a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="bg-white rounded-xl border px-4 py-6 text-center text-sm text-gray-500">
            試合履歴がありません。
          </div>
        )}
      </section>

      <!-- 招待コード -->
      <section class="bg-white rounded-xl border p-4">
        <div class="text-sm font-medium mb-1">招待コード</div>
        <div class="flex items-center gap-3">
          <span class="font-mono text-2xl font-bold tracking-widest text-blue-600">{team.inviteCode}</span>
          <button id="copy-code-btn" class="text-xs border rounded px-3 py-1.5 hover:bg-gray-50">コピー</button>
        </div>
        <p class="text-xs text-gray-400 mt-1">このコードをチームメンバーに共有してください</p>
      </section>
    </main>
  </div>
</Base>

<script define:vars={{ teamId, inviteCode: team.inviteCode }}>
  // Copy invite code
  document.getElementById('copy-code-btn')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(inviteCode)
    const btn = document.getElementById('copy-code-btn')
    if (btn) {
      btn.textContent = 'コピー済み'
      setTimeout(() => { btn.textContent = 'コピー' }, 2000)
    }
  })

  // Delete player
  document.querySelectorAll('.delete-player-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const playerId = (e.currentTarget as HTMLElement).dataset.playerId
      const playerName = (e.currentTarget as HTMLElement).dataset.playerName
      if (!confirm(`${playerName} を削除しますか？`)) return

      const res = await fetch(`/api/teams/${teamId}/players/${playerId}`, { method: 'DELETE' })
      if (res.ok) {
        location.reload()
      } else {
        alert('削除に失敗しました')
      }
    })
  })
</script>
