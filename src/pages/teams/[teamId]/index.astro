---
import Base from '../../../layouts/Base.astro'
import { getDb } from '../../../lib/db'
import { teams, teamMembers, players, matches } from '../../../schema'
import { eq, and, desc } from 'drizzle-orm'

const user = Astro.locals.user!
import { env } from 'cloudflare:workers'
const db = getDb(env.DB)
const { teamId } = Astro.params as { teamId: string }

const membership = await db.select().from(teamMembers)
  .where(and(eq(teamMembers.teamId, teamId), eq(teamMembers.userId, user.id))).get()
if (!membership) return Astro.redirect('/dashboard')

const team = await db.select().from(teams).where(eq(teams.id, teamId)).get()
if (!team) return Astro.redirect('/dashboard')

const teamPlayers = await db.select().from(players).where(eq(players.teamId, teamId))
const recentMatches = await db.select().from(matches)
  .where(eq(matches.teamId, teamId))
  .orderBy(desc(matches.createdAt))
  .limit(10)

const isOwner = membership.role === 'owner'
const positionLabel: Record<string, string> = {
  S: 'S', OH: 'OH', MB: 'MB', OP: 'OP', L: 'L',
}
const positionFull: Record<string, string> = {
  S: 'セッター', OH: 'アウトサイドヒッター', MB: 'ミドルブロッカー', OP: 'オポジット', L: 'リベロ',
}
---
<Base title={team.name}>
  <div class="min-h-screen bg-slate-50">
    <header class="app-header px-2 py-2 sticky top-0 z-10">
      <div class="max-w-2xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-2">
          <a href="/dashboard" class="flex items-center justify-center min-h-[44px] min-w-[44px] px-3 text-slate-300 hover:text-white text-lg font-bold transition-colors rounded-lg hover:bg-white/10">←</a>
          <span class="text-sm font-semibold text-white">{team.name}</span>
        </div>
        <span class="font-mono text-xs text-slate-400 bg-slate-800 rounded px-2 py-1">{team.inviteCode}</span>
      </div>
    </header>

    <main class="max-w-2xl mx-auto p-4 space-y-5">
      <!-- Players -->
      <section>
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-sm font-semibold text-slate-900">
            選手一覧
            <span class="text-slate-400 font-normal ml-1">({teamPlayers.length})</span>
          </h2>
          {isOwner && (
            <a href={`/teams/${teamId}/players/new`} class="btn-primary text-xs px-3 py-1.5">+ 追加</a>
          )}
        </div>

        {teamPlayers.length > 0 ? (
          <div class="card divide-y divide-slate-100">
            {teamPlayers.map((p) => (
              <div class="flex items-center justify-between px-4 py-3">
                <div class="flex items-center gap-3">
                  <span class="score-number text-sm font-mono text-slate-400 w-7 text-right">
                    {p.number}
                  </span>
                  <div>
                    <span class="text-sm font-medium text-slate-800">{p.name}</span>
                    {p.position && (
                      <span class="ml-2 text-xs text-slate-400" title={positionFull[p.position]}>
                        {positionLabel[p.position]}
                      </span>
                    )}
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  {p.isLibero && <span class="badge-libero">リベロ</span>}
                  {isOwner && (
                    <button
                      data-player-id={p.id}
                      data-player-name={p.name}
                      data-player-number={p.number}
                      data-player-position={p.position ?? ''}
                      data-player-libero={p.isLibero ? '1' : '0'}
                      class="edit-player-btn text-xs text-slate-400 hover:text-blue-500 transition-colors px-1">
                      編集
                    </button>
                  )}
                  {isOwner && (
                    <button data-player-id={p.id} data-player-name={p.name}
                      class="delete-player-btn text-xs text-slate-300 hover:text-red-500 transition-colors px-1">
                      削除
                    </button>
                  )}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="card px-4 py-6 text-center">
            <p class="text-sm text-slate-500">選手が登録されていません</p>
          </div>
        )}
      </section>

      <!-- Matches -->
      <section>
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-sm font-semibold text-slate-900">試合履歴</h2>
          <a href={`/matches/new?teamId=${teamId}`} class="btn-accent text-xs px-3 py-1.5">+ 試合を記録</a>
        </div>

        {recentMatches.length > 0 ? (
          <div class="card divide-y divide-slate-100">
            {recentMatches.map((match) => {
              const href = match.status === 'in_progress'
                ? `/matches/${match.id}/record`
                : `/matches/${match.id}/result`
              return (
                <div class="flex items-center justify-between px-4 py-3 hover:bg-slate-50 transition-colors">
                  <a href={href} class="flex-1 min-w-0 mr-3">
                    <div class="text-sm font-medium text-slate-800 truncate">
                      {team.name} <span class="text-slate-400 font-normal">vs</span> {match.opponentName}
                    </div>
                    <div class="text-xs text-slate-400 mt-0.5">
                      {match.matchDate}{match.location ? ` · ${match.location}` : ''}
                    </div>
                  </a>
                  <div class="flex items-center gap-2 shrink-0">
                    <span class={match.status === 'completed' ? 'badge-done' : 'badge-active'}>
                      {match.status === 'completed' ? '終了' : '● 進行中'}
                    </span>
                    {isOwner && (
                      <button
                        data-match-id={match.id}
                        data-match-name={`${team.name} vs ${match.opponentName}`}
                        class="delete-match-btn text-xs text-slate-300 hover:text-red-500 transition-colors px-2 py-1"
                      >
                        削除
                      </button>
                    )}
                  </div>
                </div>
              )
            })}
          </div>
        ) : (
          <div class="card px-4 py-6 text-center">
            <p class="text-sm text-slate-500">試合履歴がありません</p>
            <a href={`/matches/new?teamId=${teamId}`} class="inline-block mt-3 btn-accent text-xs px-4 py-1.5">+ 試合を記録</a>
          </div>
        )}
      </section>

      <!-- Invite code -->
      <section class="card p-4">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold text-slate-900">招待コード</h2>
          <button id="copy-code-btn" class="btn-secondary text-xs px-3 py-1.5">コピー</button>
        </div>
        <div class="bg-slate-900 rounded px-4 py-3 text-center">
          <span class="font-mono text-2xl font-bold text-white tracking-widest score-number">{team.inviteCode}</span>
        </div>
        <p class="text-xs text-slate-400 mt-2">このコードをチームメンバーに共有してください</p>
      </section>
    </main>
  </div>

  <!-- 選手編集ダイアログ（<body>内に配置する必要あり） -->
  <dialog id="edit-player-dialog" class="rounded-xl shadow-xl p-0 w-full max-w-sm backdrop:bg-black/40">
    <div class="p-5">
      <h2 class="text-base font-semibold text-slate-900 mb-4">選手を編集</h2>
      <form id="edit-player-form" class="space-y-4">
        <input type="hidden" id="edit-player-id" />
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="edit-name">名前</label>
          <input id="edit-name" name="name" type="text" required class="field-input" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="edit-number">背番号</label>
          <input id="edit-number" name="number" type="number" required min="0" max="99" class="field-input" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="edit-position">ポジション</label>
          <select id="edit-position" name="position" class="field-input">
            <option value="">未設定</option>
            <option value="S">セッター (S)</option>
            <option value="OH">アウトサイドヒッター (OH)</option>
            <option value="MB">ミドルブロッカー (MB)</option>
            <option value="OP">オポジット (OP)</option>
            <option value="L">リベロ (L)</option>
          </select>
        </div>
        <label class="flex items-center gap-3 cursor-pointer">
          <input id="edit-is-libero" name="isLibero" type="checkbox"
            class="w-4 h-4 rounded border-slate-300 text-blue-600 accent-blue-700" />
          <span class="text-sm text-slate-700">リベロとして登録</span>
        </label>
        <p id="edit-error-msg" class="hidden text-sm text-red-600 bg-red-50 border border-red-100 rounded px-3 py-2"></p>
        <div class="flex gap-2 pt-1">
          <button type="button" id="edit-cancel-btn" class="flex-1 btn-secondary py-2.5">キャンセル</button>
          <button type="submit" id="edit-submit-btn" class="flex-1 btn-primary py-2.5">保存する</button>
        </div>
      </form>
    </div>
  </dialog>

  <script define:vars={{ teamId, inviteCode: team.inviteCode }}>
    document.getElementById('copy-code-btn')?.addEventListener('click', async () => {
      await navigator.clipboard.writeText(inviteCode)
      const btn = document.getElementById('copy-code-btn')
      if (btn) {
        btn.textContent = 'コピー済み'
        setTimeout(() => { btn.textContent = 'コピー' }, 2000)
      }
    })

    const editDialog = document.getElementById('edit-player-dialog')
    const editForm = document.getElementById('edit-player-form')
    const editIdInput = document.getElementById('edit-player-id')
    const editNameInput = document.getElementById('edit-name')
    const editNumberInput = document.getElementById('edit-number')
    const editPositionSelect = document.getElementById('edit-position')
    const editIsLiberoCheck = document.getElementById('edit-is-libero')
    const editErrorMsg = document.getElementById('edit-error-msg')
    const editSubmitBtn = document.getElementById('edit-submit-btn')
    const editCancelBtn = document.getElementById('edit-cancel-btn')

    if (editIsLiberoCheck && editPositionSelect) {
      editIsLiberoCheck.addEventListener('change', () => {
        if (editIsLiberoCheck.checked) editPositionSelect.value = 'L'
        else if (editPositionSelect.value === 'L') editPositionSelect.value = ''
      })
      editPositionSelect.addEventListener('change', () => {
        if (editPositionSelect.value === 'L') editIsLiberoCheck.checked = true
        else editIsLiberoCheck.checked = false
      })
    }

    document.querySelectorAll('.edit-player-btn').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const el = e.currentTarget
        if (!editDialog || !editIdInput || !editNameInput || !editNumberInput || !editPositionSelect || !editIsLiberoCheck || !editErrorMsg) return
        editIdInput.value = el.dataset.playerId
        editNameInput.value = el.dataset.playerName
        editNumberInput.value = el.dataset.playerNumber
        editPositionSelect.value = el.dataset.playerPosition ?? ''
        editIsLiberoCheck.checked = el.dataset.playerLibero === '1'
        editErrorMsg.classList.add('hidden')
        editDialog.showModal()
      })
    })

    editCancelBtn?.addEventListener('click', () => editDialog?.close())

    editForm?.addEventListener('submit', async (e) => {
      e.preventDefault()
      if (!editSubmitBtn || !editErrorMsg || !editIdInput || !editNameInput || !editNumberInput || !editPositionSelect || !editIsLiberoCheck || !editDialog) return
      editSubmitBtn.disabled = true
      editSubmitBtn.textContent = '保存中...'
      editErrorMsg.classList.add('hidden')
      const playerId = editIdInput.value
      const res = await fetch(`/api/teams/${teamId}/players/${playerId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: editNameInput.value,
          number: Number(editNumberInput.value),
          position: editPositionSelect.value || null,
          isLibero: editIsLiberoCheck.checked,
        }),
      })
      if (res.ok) {
        editDialog.close()
        location.reload()
      } else {
        const data = await res.json()
        editErrorMsg.textContent = data.error ?? 'エラーが発生しました'
        editErrorMsg.classList.remove('hidden')
        editSubmitBtn.disabled = false
        editSubmitBtn.textContent = '保存する'
      }
    })

    document.querySelectorAll('.delete-player-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const el = e.currentTarget
        if (!confirm(`${el.dataset.playerName} を削除しますか？`)) return
        const res = await fetch(`/api/teams/${teamId}/players/${el.dataset.playerId}`, { method: 'DELETE' })
        if (res.ok) location.reload()
        else alert('削除に失敗しました')
      })
    })

    document.querySelectorAll('.delete-match-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation()
        const el = e.currentTarget
        if (!confirm(`「${el.dataset.matchName}」を削除しますか？`)) return
        const res = await fetch(`/api/matches/${el.dataset.matchId}`, { method: 'DELETE' })
        if (res.ok) location.reload()
        else alert('削除に失敗しました')
      })
    })
  </script>
</Base>
