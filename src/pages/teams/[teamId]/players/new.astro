---
import Base from '../../../../layouts/Base.astro'
import { getDb } from '../../../../lib/db'
import { teams, teamMembers } from '../../../../schema'
import { eq, and } from 'drizzle-orm'

const user = Astro.locals.user!
import { env } from 'cloudflare:workers'
const db = getDb(env.DB)
const { teamId } = Astro.params as { teamId: string }

const membership = await db.select().from(teamMembers)
  .where(and(eq(teamMembers.teamId, teamId), eq(teamMembers.userId, user.id))).get()

if (!membership) return Astro.redirect('/dashboard')

const team = await db.select().from(teams).where(eq(teams.id, teamId)).get()
if (!team) return Astro.redirect('/dashboard')
---
<Base title="選手を追加">
  <div class="min-h-screen bg-gray-50">
    <header class="bg-white border-b px-4 py-3 flex items-center gap-3 sticky top-0">
      <a href={`/teams/${teamId}`} class="text-gray-500 hover:text-gray-700 text-sm">← {team.name}</a>
      <span class="font-semibold">選手を追加</span>
    </header>

    <main class="max-w-md mx-auto p-4">
      <div class="bg-white rounded-xl border p-6 space-y-4">
        <form id="new-player-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-1" for="name">名前</label>
            <input id="name" name="name" type="text" required placeholder="山田 太郎"
              class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1" for="number">背番号</label>
            <input id="number" name="number" type="number" required min="0" max="99" placeholder="1"
              class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1" for="position">ポジション（任意）</label>
            <select id="position" name="position"
              class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
              <option value="">未設定</option>
              <option value="S">セッター (S)</option>
              <option value="OH">アウトサイドヒッター (OH)</option>
              <option value="MB">ミドルブロッカー (MB)</option>
              <option value="OP">オポジット (OP)</option>
              <option value="L">リベロ (L)</option>
            </select>
          </div>
          <div class="flex items-center gap-2">
            <input id="isLibero" name="isLibero" type="checkbox" class="rounded" />
            <label class="text-sm font-medium" for="isLibero">リベロとして登録</label>
          </div>
          <p id="error-msg" class="text-red-500 text-sm hidden"></p>
          <button type="submit"
            class="w-full bg-blue-600 text-white rounded-lg py-2.5 font-medium text-sm hover:bg-blue-700 disabled:opacity-50">
            追加する
          </button>
        </form>
      </div>
    </main>
  </div>
</Base>

<script define:vars={{ teamId }}>
  const form = document.getElementById('new-player-form')
  const errorMsg = document.getElementById('error-msg')
  const btn = form.querySelector('button[type="submit"]')

  // リベロにチェックを入れたらpositionをLにセット
  const isLiberoCheck = document.getElementById('isLibero')
  const positionSelect = document.getElementById('position')
  isLiberoCheck.addEventListener('change', () => {
    if (isLiberoCheck.checked) positionSelect.value = 'L'
  })

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    btn.disabled = true
    btn.textContent = '追加中...'
    errorMsg.classList.add('hidden')

    const fd = new FormData(form)
    const res = await fetch(`/api/teams/${teamId}/players`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: fd.get('name'),
        number: Number(fd.get('number')),
        position: fd.get('position') || undefined,
        isLibero: isLiberoCheck.checked,
      }),
    })

    if (res.ok) {
      location.href = `/teams/${teamId}`
    } else {
      const data = await res.json()
      errorMsg.textContent = data.error ?? 'エラーが発生しました'
      errorMsg.classList.remove('hidden')
      btn.disabled = false
      btn.textContent = '追加する'
    }
  })
</script>
