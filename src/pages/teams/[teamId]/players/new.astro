---
import Base from '../../../../layouts/Base.astro'
import { getDb } from '../../../../lib/db'
import { teams, teamMembers } from '../../../../schema'
import { eq, and } from 'drizzle-orm'

const user = Astro.locals.user!
import { env } from 'cloudflare:workers'
const db = getDb(env.DB)
const { teamId } = Astro.params as { teamId: string }

const membership = await db.select().from(teamMembers)
  .where(and(eq(teamMembers.teamId, teamId), eq(teamMembers.userId, user.id))).get()
if (!membership) return Astro.redirect('/dashboard')

const team = await db.select().from(teams).where(eq(teams.id, teamId)).get()
if (!team) return Astro.redirect('/dashboard')
---
<Base title="選手を追加">
  <div class="min-h-screen bg-slate-50">
    <header class="app-header px-4 py-3 sticky top-0 z-10">
      <div class="max-w-2xl mx-auto flex items-center gap-3">
        <a href={`/teams/${teamId}`} class="text-slate-400 hover:text-white text-sm transition-colors">← {team.name}</a>
        <span class="text-slate-600">|</span>
        <span class="text-sm font-semibold text-white">選手を追加</span>
      </div>
    </header>

    <main class="max-w-md mx-auto p-4 pt-6">
      <div class="card p-6">
        <h1 class="text-base font-semibold text-slate-900 mb-5">新しい選手</h1>
        <form id="new-player-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5" for="name">名前</label>
            <input id="name" name="name" type="text" required placeholder="山田 太郎"
              class="field-input" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5" for="number">背番号</label>
            <input id="number" name="number" type="number" required min="0" max="99" placeholder="1"
              class="field-input" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5" for="position">ポジション（任意）</label>
            <select id="position" name="position" class="field-input">
              <option value="">未設定</option>
              <option value="S">セッター (S)</option>
              <option value="OH">アウトサイドヒッター (OH)</option>
              <option value="MB">ミドルブロッカー (MB)</option>
              <option value="OP">オポジット (OP)</option>
              <option value="L">リベロ (L)</option>
            </select>
          </div>
          <label class="flex items-center gap-3 cursor-pointer">
            <input id="isLibero" name="isLibero" type="checkbox"
              class="w-4 h-4 rounded border-slate-300 text-blue-600 accent-blue-700" />
            <span class="text-sm text-slate-700">リベロとして登録</span>
          </label>
          <p id="error-msg" class="hidden text-sm text-red-600 bg-red-50 border border-red-100 rounded px-3 py-2"></p>
          <button type="submit" class="btn-primary w-full py-2.5">追加する</button>
        </form>
      </div>
    </main>
  </div>
</Base>

<script define:vars={{ teamId }}>
  const form = document.getElementById('new-player-form')
  const errorMsg = document.getElementById('error-msg')
  const btn = form.querySelector('button[type="submit"]')
  const isLiberoCheck = document.getElementById('isLibero')
  const positionSelect = document.getElementById('position')

  isLiberoCheck.addEventListener('change', () => {
    if (isLiberoCheck.checked) positionSelect.value = 'L'
  })

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    btn.disabled = true
    btn.textContent = '追加中...'
    errorMsg.classList.add('hidden')

    const fd = new FormData(form)
    const res = await fetch(`/api/teams/${teamId}/players`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: fd.get('name'),
        number: Number(fd.get('number')),
        position: fd.get('position') || undefined,
        isLibero: isLiberoCheck.checked,
      }),
    })

    if (res.ok) {
      location.href = `/teams/${teamId}`
    } else {
      const data = await res.json()
      errorMsg.textContent = data.error ?? 'エラーが発生しました'
      errorMsg.classList.remove('hidden')
      btn.disabled = false
      btn.textContent = '追加する'
    }
  })
</script>
