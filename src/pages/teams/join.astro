---
import Base from '../../layouts/Base.astro'
---
<Base title="チームに参加">
  <div class="min-h-screen bg-gray-50">
    <header class="bg-white border-b px-4 py-3 flex items-center gap-3 sticky top-0">
      <a href="/dashboard" class="text-gray-500 hover:text-gray-700 text-sm">← ダッシュボード</a>
      <span class="font-semibold">招待コードで参加</span>
    </header>

    <main class="max-w-md mx-auto p-4">
      <div class="bg-white rounded-xl border p-6 space-y-4">
        <p class="text-sm text-gray-500">
          チームのオーナーから受け取った6文字の招待コードを入力してください。
        </p>
        <form id="join-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-1" for="code">招待コード</label>
            <input
              id="code" name="code" type="text" required
              placeholder="ABCDEF"
              maxlength="6"
              class="w-full border rounded-lg px-3 py-2 text-sm font-mono uppercase tracking-widest text-center focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>
          <p id="error-msg" class="text-red-500 text-sm hidden"></p>
          <button
            type="submit"
            class="w-full bg-blue-600 text-white rounded-lg py-2.5 font-medium text-sm hover:bg-blue-700 disabled:opacity-50"
          >
            参加する
          </button>
        </form>
      </div>
    </main>
  </div>
</Base>

<script>
  const form = document.getElementById('join-form') as HTMLFormElement
  const errorMsg = document.getElementById('error-msg') as HTMLParagraphElement
  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement
  const codeInput = document.getElementById('code') as HTMLInputElement

  // Auto uppercase
  codeInput.addEventListener('input', () => {
    codeInput.value = codeInput.value.toUpperCase()
  })

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    btn.disabled = true
    btn.textContent = '参加中...'
    errorMsg.classList.add('hidden')

    const fd = new FormData(form)
    const res = await fetch('/api/teams/join', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ code: fd.get('code') }),
    })

    if (res.ok) {
      const data = await res.json() as { teamId: string }
      location.href = `/teams/${data.teamId}`
    } else {
      const data = await res.json() as { error?: string }
      errorMsg.textContent = data.error ?? 'エラーが発生しました'
      errorMsg.classList.remove('hidden')
      btn.disabled = false
      btn.textContent = '参加する'
    }
  })
</script>
