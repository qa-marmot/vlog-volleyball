---
import Base from '../../layouts/Base.astro'
---
<Base title="チーム作成">
  <div class="min-h-screen bg-slate-50">
    <header class="app-header px-4 py-3 sticky top-0 z-10">
      <div class="max-w-2xl mx-auto flex items-center gap-3">
        <a href="/dashboard" class="text-slate-400 hover:text-white text-sm transition-colors">← ダッシュボード</a>
        <span class="text-slate-600">|</span>
        <span class="text-sm font-semibold text-white">チームを作成</span>
      </div>
    </header>

    <main class="max-w-md mx-auto p-4 pt-6">
      <div class="card p-6">
        <h1 class="text-base font-semibold text-slate-900 mb-5">新しいチーム</h1>
        <form id="new-team-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5" for="name">チーム名</label>
            <input id="name" name="name" type="text" required placeholder="例：○○バレーボール部"
              class="field-input" />
          </div>
          <p id="error-msg" class="hidden text-sm text-red-600 bg-red-50 border border-red-100 rounded px-3 py-2"></p>
          <button type="submit" class="btn-primary w-full py-2.5">作成する</button>
        </form>
      </div>
    </main>
  </div>
</Base>

<script>
  const form = document.getElementById('new-team-form') as HTMLFormElement
  const errorMsg = document.getElementById('error-msg') as HTMLParagraphElement
  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    btn.disabled = true
    btn.textContent = '作成中...'
    errorMsg.classList.add('hidden')

    const fd = new FormData(form)
    const res = await fetch('/api/teams', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: fd.get('name') }),
    })

    if (res.ok) {
      const data = await res.json() as { id: string }
      location.href = `/teams/${data.id}`
    } else {
      const data = await res.json() as { error?: string }
      errorMsg.textContent = data.error ?? 'エラーが発生しました'
      errorMsg.classList.remove('hidden')
      btn.disabled = false
      btn.textContent = '作成する'
    }
  })
</script>
