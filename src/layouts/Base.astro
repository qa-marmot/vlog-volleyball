---
interface Props {
  title?: string
}
const { title = 'V-Log' } = Astro.props
---
<!doctype html>
<html lang="ja" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <title>{title} | V-Log</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-full antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @import "tailwindcss";

  /* ── Volleyball theme design tokens ── */
  @theme {
    --color-vball-navy:    #0f2044;
    --color-vball-blue:    #1a56db;
    --color-vball-sky:     #3b82f6;
    --color-vball-orange:  #f97316;
    --color-vball-amber:   #fbbf24;
    --color-vball-court:   #f0f4ff;

    /* shadcn/ui token mapping */
    --color-background:          oklch(0.99 0 0);
    --color-foreground:          oklch(0.13 0.02 255);
    --color-card:                oklch(1 0 0);
    --color-card-foreground:     oklch(0.13 0.02 255);
    --color-popover:             oklch(1 0 0);
    --color-popover-foreground:  oklch(0.13 0.02 255);
    --color-primary:             #1a56db;
    --color-primary-foreground:  #ffffff;
    --color-secondary:           #f0f4ff;
    --color-secondary-foreground:#0f2044;
    --color-muted:               #f3f6ff;
    --color-muted-foreground:    #6b7280;
    --color-accent:              #f97316;
    --color-accent-foreground:   #ffffff;
    --color-destructive:         #ef4444;
    --color-destructive-foreground: #ffffff;
    --color-border:              #e2e8f0;
    --color-input:               #e2e8f0;
    --color-ring:                #1a56db;

    --radius-sm:  0.375rem;
    --radius-md:  0.5rem;
    --radius-lg:  0.75rem;
    --radius-xl:  1rem;
    --radius-2xl: 1.5rem;
  }

  :root {
    --background: oklch(0.99 0 0);
    --foreground: oklch(0.13 0.02 255);
    --card: oklch(1 0 0);
    --primary: #1a56db;
    --primary-foreground: #ffffff;
    --secondary: #f0f4ff;
    --secondary-foreground: #0f2044;
    --muted: #f3f6ff;
    --muted-foreground: #6b7280;
    --accent: #f97316;
    --accent-foreground: #ffffff;
    --destructive: #ef4444;
    --border: #e2e8f0;
    --input: #e2e8f0;
    --ring: #1a56db;
    --radius: 0.75rem;
  }

  *, *::before, *::after { box-sizing: border-box; }

  body {
    background-color: var(--background);
    color: var(--foreground);
    font-family: 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', 'Noto Sans JP', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .vball-stripe {
    background: linear-gradient(135deg, #1a56db 0%, #0f2044 50%, #1a56db 100%);
  }

  .vball-header {
    background: linear-gradient(135deg, #0f2044 0%, #1a3a8f 60%, #1a56db 100%);
    color: #ffffff;
  }

  .score-number {
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum";
  }

  /* Radix Dialog animations */
  @keyframes fadeIn  { from { opacity: 0 } to { opacity: 1 } }
  @keyframes fadeOut { from { opacity: 1 } to { opacity: 0 } }
  @keyframes zoomIn  { from { transform: translate(-50%,-50%) scale(0.95) } to { transform: translate(-50%,-50%) scale(1) } }
  @keyframes zoomOut { from { transform: translate(-50%,-50%) scale(1) } to { transform: translate(-50%,-50%) scale(0.95) } }

  [data-state=open][data-slot=dialog-overlay]  { animation: fadeIn  150ms ease; }
  [data-state=closed][data-slot=dialog-overlay] { animation: fadeOut 150ms ease; }
  [data-state=open][data-slot=dialog-content]   { animation: zoomIn  150ms ease; }
  [data-state=closed][data-slot=dialog-content] { animation: zoomOut 150ms ease; }
</style>
